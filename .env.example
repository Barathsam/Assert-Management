# Copy to .env. The docker-compose setup already injects these for the app container;
# this file is what you need when running `npm run dev` against a local Postgres.
NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5433
DB_NAME=asset_management
DB_USER=postgres
DB_PASSWORD=postgres

SESSION_SECRET=change-me-in-production
TZ=UTC
