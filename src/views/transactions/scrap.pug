extends ../layout

include ../partials/asset-summary

block content
  .row.justify-content-center
    .col-lg-7
      h1.page-title.mb-3 Scrap Asset

      +assetSummary(asset)

      .card.border-danger
        .card-header.bg-danger.text-white.fw-semibold
          i.bi.bi-exclamation-triangle.me-2
          | This cannot be undone
        .card-body
          p.small.text-muted
            | Scrapping marks the asset obsolete. It will disappear from Assets, Stock, Issue and
            |  Return, and can never be issued again. Its full history stays available under Reports —
            |  that is the point of scrapping rather than deleting.

          form(method="post" action=`/assets/${asset.id}/scrap` data-once)

            //- Scrapping an issued asset would strand the holding open and lose the record of
            //- who had it last — exactly what you most need when writing something off. So we
            //- don't refuse; we collect the return details here and do both in one transaction.
            if asset.status === 'ISSUED'
              .alert.alert-warning.small
                i.bi.bi-info-circle.me-1
                | This asset is still issued to
                strong=` ${asset.holder.firstName} ${asset.holder.lastName}`
                | . It will be returned from them first, and both the return and the scrap will be
                |  recorded. That way the history still shows who held it last.
              .mb-3
                label.form-label Return Reason *
                select.form-select(name="returnReason" required)
                  option(value="") Select a reason…
                  each r in reasons
                    option(value=r)= RETURN_REASON_LABEL[r]

            .row
              .col-md-6.mb-3
                label.form-label Scrap Date *
                input.form-control(type="date" name="date" required value=today max=today)
              .col-md-6.mb-3
                label.form-label Scrap Value Recovered (₹)
                input.form-control(type="number" name="scrapValue" min="0" step="0.01" value="0")
                .form-text Subtracted from the asset's net cost. Zero if nothing was recovered.

            .mb-3
              label.form-label Reason for Scrapping *
              textarea.form-control(name="reason" rows="2" required placeholder="Beyond economic repair")

            .d-flex.justify-content-end.gap-2
              a.btn.btn-outline-secondary(href=`/assets/${asset.id}`) Cancel
              button.btn.btn-danger(type="submit") Scrap Asset
