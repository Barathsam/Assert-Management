{
    "name": "asset-management",
    "version": "1.0.0",
    "private": true,
    "description": "Asset Management System — track company assets issued to employees",
    "main": "dist/server.js",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc -p tsconfig.build.json",
        "start": "node dist/server.js",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "db:migrate": "sequelize-cli db:migrate",
        "db:migrate:undo": "sequelize-cli db:migrate:undo:all",
        "db:seed": "sequelize-cli db:seed:all",
        "db:seed:undo": "sequelize-cli db:seed:undo:all",
        "db:reset": "npm run db:migrate:undo && npm run db:migrate && npm run db:seed",
        "test": "vitest --run --coverage.enabled=true",
        "testOnce": "vitest --run --coverage.enabled=true --coverage.thresholds.autoUpdate=true",
        "t": "vitest --coverage.enabled=false",
        "trun": "vitest run --coverage.enabled=false"
    },
    "engines": {
        "node": ">=20"
    },
    "dependencies": {
        "bootstrap": "^5.3.3",
        "bootstrap-icons": "^1.11.3",
        "connect-flash": "^0.1.1",
        "datatables.net-bs5": "^2.2.1",
        "datatables.net-responsive-bs5": "^3.0.3",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "express-session": "^1.18.1",
        "joi": "^18.2.3",
        "jquery": "^3.7.1",
        "morgan": "^1.10.0",
        "pg": "^8.13.1",
        "pg-hstore": "^2.3.4",
        "pug": "^3.0.3",
        "sequelize": "^6.37.5"
    },
    "devDependencies": {
        "@eslint/js": "^9.17.0",
        "@faker-js/faker": "^10.5.0",
        "@types/connect-flash": "^0.0.40",
        "@types/express": "^4.17.21",
        "@types/express-session": "^1.18.1",
        "@types/morgan": "^1.9.9",
        "@types/node": "^22.10.2",
        "@types/supertest": "^7.2.0",
        "@vitest/coverage-v8": "^4.1.10",
        "@vitest/eslint-plugin": "^1.6.23",
        "eslint": "^9.17.0",
        "eslint-plugin-prefer-arrow-functions": "^3.10.1",
        "globals": "^17.7.0",
        "prettier": "^3.4.2",
        "sequelize-cli": "^6.6.2",
        "supertest": "^7.2.2",
        "tsx": "^4.19.2",
        "typescript": "^5.7.2",
        "typescript-eslint": "^8.18.1",
        "vitest": "^4.1.10"
    }
}
